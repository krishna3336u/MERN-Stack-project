<style>
  /* Custom Search Button */
  .btn-search {
    background-color: #fe424d !important;
    color: #fff !important;
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
    border: none;
    transition: 0.3s;
  }
  .btn-search:hover {
    background-color: #d93a44 !important;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }
  .btn-search i {
    margin-right: 0.5rem;
  }

  /* Custom Search Input */
  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1rem;
    border: 1px solid #ced4da;
  }

  /* Mobile Adjustments */
  @media (max-width: 767.98px) {
    .navbar-collapse {
      padding-bottom: 1rem;
      text-align: center; /* Centers links on mobile */
    }
    .search-form {
      margin-bottom: 1.5rem; /* Space below search bar on mobile */
      justify-content: center !important;
    }
    .nav-link {
      padding: 0.8rem 0; /* Better touch targets for fingers */
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-white border-bottom sticky-top shadow-sm">
  <div class="container">
    <!-- Brand Logo -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass" style="color: #fe424d; font-size: 1.5rem;"></i> 
      <span class="ms-1 fw-bold">Krishna singh website</span>
    </a>

    <!-- Mobile Toggle Button -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Collapsible Content -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      
      <!-- 1. Left Side Links -->
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- 2. Center Search Bar (Responsive) -->
      <form class="d-flex search-form mx-auto my-3 my-md-0" role="search">
        <input class="form-control me-2 search-inp" type="search" placeholder="Search destinations" aria-label="Search" />
        <button class="btn btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>Search
        </button>
      </form>

      <!-- 3. Right Side Links -->
      <div class="navbar-nav ms-auto align-items-md-center">
        <a class="nav-link" href="/listings/new">Add New Listing</a>
        
        <% if(!currUser) {%>
          <a class="nav-link" href="/signup"><b>Sign up</b></a> 
          <a class="nav-link" href="/login"><b>Log in</b></a>
        <%}%>
        
        <% if(currUser) {%>
          <a class="nav-link" href="/logout"><b>Log out</b></a>
        <%}%>
      </div>
      
    </div>
  </div>
</nav>