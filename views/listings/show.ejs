<% layout("/layouts/boilerplate")-%>
<div class="row mt-3">
  
  <!-- Title -->
  <div class="col-12 col-md-8 offset-md-2">
    <h3><b><%= listing.title %></b></h3>
  </div>  

  <!-- Listing Details Image + Info -->
  <div class="col-12 col-md-8 offset-md-2">
    <div class="card listing-card border-0">
      <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image">
      <div class="card-body px-0"> <!-- px-0 removes extra padding on the sides for mobile -->
        <p class="card-text"><i>Owned by <%= listing.owner ? listing.owner.username : "Anonymous" %></i></p>
        <p class="card-text"><%=listing.description%></p>
        <p class="card-text"><b>&#8377; <%= listing.price.toLocaleString("en-IN") %>/night</b></p>
        <p class="card-text"><i class="fa-solid fa-location-dot me-2"></i><%= listing.location %></p>
        <p class="card-text"><i class="fa-solid fa-globe me-2"></i><%= listing.country %></p>
      </div>
    </div>
  </div>

  <!-- Action Buttons (Edit and Delete) -->
  <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
    <div class="col-12 col-md-8 offset-md-2 d-flex gap-2 mb-3">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark px-4">Edit</a>
    
      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-danger px-3">Delete Listing</button>
      </form>
    </div>
    <div class="col-12 col-md-8 offset-md-2">
      <hr>
    </div>
  <%}%>

  <!-- Review Form Section -->
  <div class="col-12 col-md-8 offset-md-2">
    <% if(currUser) {%>
      <h4>Leave a Review</h4>
      <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation mb-4">
        
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <div class="mb-3">
          <label for="comment" class="form-label">Comments</label>
          <textarea name="review[comment]" id="comment" cols="20" rows="4" class="form-control" required></textarea>
          <div class="invalid-feedback">Please add some comments for review</div>
        </div>
        <button class="btn btn-outline-dark">Submit Review</button>
      </form>
      <hr>
    <%}%>
    
    <!-- All Reviews Display section -->
    <% if(listing.reviews.length > 0) { %>
      <p><b>All Reviews</b></p>
      <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
        <% for(review of listing.reviews) { %>
          <div class="col">
            <div class="card h-100 shadow-sm border-light">
              <div class="card-body d-flex flex-column justify-content-between">
                <div>
                  <h5 class="card-title">@<%= review.author ? review.author.username : "Unknown User" %></h5>
                  <p class="starability-result card-text mb-2" data-rating="<%=review.rating %>"></p>
                  <p class="card-text text-secondary"><%=review.comment %></p>
                </div>
                
                <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                  <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" class="mt-3">
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <%}%>
      </div>
    <%}%>
  </div>
</div>